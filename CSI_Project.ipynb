# Project: Customer Satisfaction Index (CSI) using Sentiment Analysis
# Author: MBA Business Analytics
# Tools: Python, NLTK, VADER, Matplotlib

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import nltk
from nltk.corpus import movie_reviews
from nltk.sentiment.vader import SentimentIntensityAnalyzer
from wordcloud import WordCloud

# 1. Setup & Data Loading
nltk.download('movie_reviews')
nltk.download('vader_lexicon')
nltk.download('punkt')

# Prepare the dataset
documents = [(" ".join(movie_reviews.words(fileid)), category)
             for category in movie_reviews.categories()
             for fileid in movie_reviews.fileids(category)]

df = pd.DataFrame(documents, columns=['review', 'sentiment'])
# We will use a sample for speed
df = df.sample(500, random_state=42)

# 2. Sentiment Analysis using VADER
analyzer = SentimentIntensityAnalyzer()

def calculate_vader_score(text):
    return analyzer.polarity_scores(text)['compound']

df['sentiment_score'] = df['review'].apply(calculate_vader_score)

# 3. Computing the Customer Satisfaction Index (CSI)
# Mapping VADER (-1 to 1) to CSI Scale (0 to 100)
df['CSI'] = ((df['sentiment_score'] + 1) / 2) * 100

overall_csi = df['CSI'].mean()
print(f"Overall Customer Satisfaction Index (CSI): {overall_csi:.2f}")

# 4. Visualizations
plt.figure(figsize=(10, 6))
sns.histplot(df['CSI'], kde=True, color='skyblue')
plt.title('Distribution of Customer Satisfaction Index (CSI)')
plt.xlabel('CSI Score (0-100)')
plt.ylabel('Frequency')
plt.savefig('csi_distribution.png')
plt.show()

# Word Cloud for High Satisfaction
high_sat_text = " ".join(df[df['CSI'] > 70]['review'])
wordcloud = WordCloud(width=800, height=400, background_color='white').generate(high_sat_text)
plt.figure(figsize=(10, 5))
plt.imshow(wordcloud, interpolation='bilinear')
plt.axis('off')
plt.title('Common Themes in High Satisfaction Reviews')
plt.savefig('wordcloud.png')
plt.show()
